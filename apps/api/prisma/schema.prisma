generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  EDITOR
  VIEWER
}

enum SnapshotTrigger {
  AUTO
  MANUAL
}

model User {
  id            String           @id @default(cuid())
  email         String           @unique
  name          String?
  avatarUrl     String?
  oauthProvider String?
  createdAt     DateTime         @default(now())
  memberships   BoardMember[]
  events        BoardEvent[]
  analytics     AnalyticsEvent[]
  ownedBoards   Board[]          @relation("BoardOwner")
}

model Board {
  id              String          @id @default(cuid())
  title           String          @default("Untitled Board")
  ownerId         String
  owner           User            @relation("BoardOwner", fields: [ownerId], references: [id])
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  lastEventSeq    Int             @default(0)
  lastSnapshotSeq Int             @default(0)
  lastSnapshotAt  DateTime?
  members         BoardMember[]
  events          BoardEvent[]
  snapshots       BoardSnapshot[]
  updates         BoardUpdate[]
  tasks           Task[]
  aiArtifacts     AiArtifact[]
}

model BoardMember {
  boardId  String
  userId   String
  role     Role     @default(EDITOR)
  joinedAt DateTime @default(now())
  board    Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([boardId, userId])
}

model BoardEvent {
  id        String   @id @default(uuid())
  boardId   String
  sequence  Int
  type      String
  actorId   String
  payload   Json
  clientId  String   @default("")
  createdAt DateTime @default(now())
  board     Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  actor     User     @relation(fields: [actorId], references: [id])

  @@unique([boardId, sequence])
  @@index([boardId, createdAt])
}

model BoardUpdate {
  id          String   @id @default(uuid())
  boardId     String
  sequence    Int
  yjsUpdate   Bytes
  stateVector Bytes?
  createdAt   DateTime @default(now())
  board       Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)

  @@index([boardId, sequence])
}

model BoardSnapshot {
  id           String          @id @default(uuid())
  boardId      String
  sequence     Int
  label        String?
  yjsState     Bytes
  thumbnailKey String?
  createdById  String
  createdAt    DateTime        @default(now())
  trigger      SnapshotTrigger @default(MANUAL)
  board        Board           @relation(fields: [boardId], references: [id], onDelete: Cascade)

  @@index([boardId, sequence])
}

model AiArtifact {
  id        String   @id @default(uuid())
  boardId   String
  type      String
  content   Json
  s3Key     String?
  model     String
  createdAt DateTime @default(now())
  board     Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
}

model Task {
  id         String    @id @default(uuid())
  boardId    String
  title      String
  priority   String
  assigneeId String?
  dueDate    DateTime?
  source     String    @default("AI")
  createdAt  DateTime  @default(now())
  board      Board     @relation(fields: [boardId], references: [id], onDelete: Cascade)
}

model AnalyticsEvent {
  id         String   @id @default(uuid())
  userId     String?
  boardId    String?
  name       String
  properties Json     @default("{}")
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id])

  @@index([name, createdAt])
  @@index([boardId, createdAt])
}
