{
  "name": "collabboard-plus",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "node server.js",
    "build": "next build --webpack",
    "start": "NODE_ENV=production node server.js",
    "lint": "eslint",
    "dev:api": "npm run start:dev -w @collabboard/api",
    "build:api": "npm run build -w @collabboard/api",
    "build:shared": "npm run build -w @collabboard/shared",
    "prisma:push": "npm run prisma:push -w @collabboard/api",
    "prisma:generate": "npm run prisma:generate -w @collabboard/api",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "dependencies": {
    "@clerk/nextjs": "^6.36.0",
    "@google/generative-ai": "^0.24.1",
    "@livekit/components-react": "^2.9.17",
    "@socket.io/redis-adapter": "^8.3.0",
    "@stream-io/video-react-sdk": "^1.31.0",
    "@tiptap/extension-font-family": "^3.13.0",
    "@tiptap/extension-text-style": "^3.13.0",
    "@tiptap/extension-underline": "^3.13.0",
    "@tiptap/pm": "^3.13.0",
    "@tiptap/react": "^3.13.0",
    "@tiptap/starter-kit": "^3.13.0",
    "axios": "^1.13.2",
    "bcryptjs": "^3.0.3",
    "firebase": "^12.7.0",
    "idb": "^8.0.1",
    "jsonwebtoken": "^9.0.3",
    "konva": "^9.3.18",
    "livekit-client": "^2.16.1",
    "livekit-server-sdk": "^2.15.0",
    "lucide-react": "^0.562.0",
    "mailgen": "^2.0.32",
    "mermaid": "^11.4.1",
    "nex": "^2.0.22",
    "next": "^16.0.0",
    "next-themes": "^0.4.6",
    "nodemailer": "^7.0.11",
    "openai": "^4.77.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hot-toast": "^2.6.0",
    "react-icons": "^5.5.0",
    "react-konva": "^19.0.2",
    "redis": "^4.7.0",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "uuid": "^11.0.3",
    "y-indexeddb": "^9.0.12",
    "y-websocket": "^2.0.4",
    "yjs": "^13.6.20",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.3",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.0.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
